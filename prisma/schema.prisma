generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  MASTER
  ADMIN
}

enum LandingPageStatus {
  draft
  published
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  passwordHash   String
  role           UserRole
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  pagesUpdated   LandingPage[] @relation("LandingPageUpdatedBy")
  pagesPublished LandingPage[] @relation("LandingPagePublishedBy")
  createdAssets  Asset[]
}

model LandingPage {
  id               String            @id @default(cuid())
  slug             String            @unique
  title            String
  seoTitle         String?
  seoDescription   String?
  status           LandingPageStatus @default(draft)
  draftContent     Json
  publishedContent Json?
  publishedAt      DateTime?
  updatedAt        DateTime          @updatedAt
  createdAt        DateTime          @default(now())
  updatedById      String
  updatedBy        User              @relation("LandingPageUpdatedBy", fields: [updatedById], references: [id])
  publishedById    String?
  publishedBy      User?             @relation("LandingPagePublishedBy", fields: [publishedById], references: [id])
}

model Asset {
  id               String   @id @default(cuid())
  kind             String
  entityType       String
  entityId         String
  sectionKey       String?
  fieldKey         String?
  slot             Int?
  pathname         String
  url              String
  mimeType         String
  sizeBytes        Int
  originalFilename String?
  alt              String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      String
  createdBy        User     @relation(fields: [createdById], references: [id])

  @@index([pathname])
  @@index([url])
  @@index([entityType, entityId, sectionKey, fieldKey, slot])
}
